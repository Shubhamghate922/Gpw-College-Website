/* ── Sticky navbar shadow on scroll ── */
(function () {
  const navbar = document.getElementById('navbar');

  window.addEventListener('scroll', function () {
    if (window.scrollY > 10) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  }, { passive: true });
})();

/* ── HOME CLICK → RELOAD PAGE ── */
document.getElementById('homeLink').addEventListener('click', function (e) {
  e.preventDefault();
  location.reload();
});


/* ── ACTIVE NAV ITEM + UNDERLINE ── */
(function () {
  const navItems = document.querySelectorAll('.nav-item');

  navItems.forEach(function (item) {
    const link = item.querySelector('.nav-link');

    link.addEventListener('click', function () {

      // Remove active from all
      navItems.forEach(i => {
        i.classList.remove('active');
        const ul = i.querySelector('.nav-underline');
        if (ul) ul.style.width = '0';
      });

      // Set active
      item.classList.add('active');

      // Add underline if not exist
      let underline = item.querySelector('.nav-underline');
      if (!underline) {
        underline = document.createElement('span');
        underline.classList.add('nav-underline');
        item.appendChild(underline);
      }

      // Animate
      requestAnimationFrame(() => {
        underline.style.width = 'calc(100% - 24px)';
      });
    });
  });

})();

/* ── DROPDOWN TOGGLE (ABOUT US) ── */
(function () {
  const dropdownItem = document.querySelector('.nav-item.has-dropdown');
  const link = dropdownItem.querySelector('.nav-link');

  link.addEventListener('click', function (e) {
    e.preventDefault(); // stop page jump

    // toggle open/close
    dropdownItem.classList.toggle('open');
  });

  // Close when clicking outside
  document.addEventListener('click', function (e) {
    if (!dropdownItem.contains(e.target)) {
      dropdownItem.classList.remove('open');
    }
  });
})();

/* ── Active nav item underline with smooth animation ── */
(function () {
  const navItems = document.querySelectorAll('.nav-item');
  const navLinks = document.querySelectorAll('.nav-item .nav-link');

  navLinks.forEach(function (link) {
    link.addEventListener('click', function (e) {
      const parentItem = link.closest('.nav-item');

      // Skip if it's a dropdown toggle – let dropdown open naturally
      if (parentItem.classList.contains('has-dropdown')) {
        // Still update active state
      }

      // Remove active from all items
      navItems.forEach(function (item) {
        item.classList.remove('active');
        // Remove injected underline spans on items that aren't Home
        const ul = item.querySelector('.nav-underline');
        if (!ul) return;
        // animate out
        ul.style.width = '0';
      });

      // Add active to clicked item
      parentItem.classList.add('active');

      // If clicked item has no underline span, inject one
      let underline = parentItem.querySelector('.nav-underline');
      if (!underline) {
        underline = document.createElement('span');
        underline.classList.add('nav-underline');
        parentItem.appendChild(underline);
      }

      // Force a reflow so transition fires
      void underline.offsetWidth;
      underline.style.width = 'calc(100% - 24px)';
    });
  });
})();




